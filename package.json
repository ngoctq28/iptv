{
  "name": "iptv",
  "version": "1.0.0",
  "description": "A lightweight, responsive web application that allows users to stream IPTV channels directly in their browser.",
  "main": "hls.light.min.js",
  "scripts": {
    "build": "webpack --mode production",
    "start": "NODE_ENV=production node server.js",
    "start:win": "cross-env NODE_ENV=production node server.js",
    "dev": "concurrently --kill-others \"cross-env PORT=3001 nodemon server.js\" \"webpack serve --mode development\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
